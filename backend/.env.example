# Flask
FLASK_ENV=development
SECRET_KEY=your-flask-secret-key

# PostgreSQL credentials (used by docker-compose db service and to build DATABASE_URL)
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=dataroom

# Connection URL — for local Python dev use localhost; Docker sets this from the vars above
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/dataroom

# Token encryption (generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())")
FERNET_KEY=your-fernet-key-here

# Google OAuth
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=http://localhost:5001/oauth/google-drive/callback

# CORS — frontend origin
FRONTEND_URL=http://localhost:3000

# File storage directory (default: ./uploads relative to backend/)
# UPLOAD_DIR=/absolute/path/to/uploads

# Firebase Admin SDK — paste the entire service-account JSON as one line.
# Download from Firebase Console → Project settings → Service accounts → Generate new private key.
# Leave empty to use the legacy X-Owner-ID fallback (local dev only).
FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"...","private_key_id":"..."}

# Set to "true" to reject X-Owner-ID fallback and require Bearer token in all environments.
FIREBASE_AUTH_REQUIRED=true
