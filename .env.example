# Firebase — create a project at https://console.firebase.google.com
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# Storage adapter: 'flask' | 'indexeddb'
NEXT_PUBLIC_STORAGE_ADAPTER=flask

# Flask backend URL — only needed if NEXT_PUBLIC_STORAGE_ADAPTER=flask
NEXT_PUBLIC_BACKEND_URL=http://localhost:5001

# Google Drive Picker — required for "Import from Google Drive"
# Client ID: Google Cloud Console → APIs & Services → Credentials → OAuth 2.0 Client ID
# API Key:   Google Cloud Console → APIs & Services → Credentials → API Key
#            (restrict to Google Picker API)
NEXT_PUBLIC_GOOGLE_CLIENT_ID=
NEXT_PUBLIC_GOOGLE_API_KEY=

